# Personal AI Employee - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# =============================================================
# VAULT CONFIGURATION (Required)
# =============================================================
VAULT_PATH=/path/to/your/AI_Employee_Vault

# =============================================================
# GMAIL CONFIGURATION (Required for Gmail Watcher)
# =============================================================
GMAIL_CREDENTIALS_PATH=/path/to/credentials.json
GMAIL_TOKEN_PATH=/path/to/token.json
GMAIL_MAX_RESULTS=10

# =============================================================
# BANKING API (Optional - for Finance Watcher)
# =============================================================
BANK_API_TOKEN=your_bank_api_token
BANK_API_URL=https://api.yourbank.com/v1

# =============================================================
# WHATSAPP (Optional - for Silver tier)
# =============================================================
WHATSAPP_SESSION_PATH=/secure/path/to/whatsapp_session

# =============================================================
# SLACK (Optional)
# =============================================================
SLACK_API_KEY=your_slack_api_key
SLACK_CHANNEL_ID=your_channel_id

# =============================================================
# ODOO (Optional - Gold/Platinum tier)
# =============================================================
ODOO_URL=https://odoo.yoursite.com
ODOO_DB=your_database
ODOO_UID=1
ODOO_PASSWORD=your_password

# =============================================================
# RUNTIME FLAGS
# =============================================================
DRY_RUN=true
DEBUG=false
LOG_LEVEL=INFO

# =============================================================
# RATE LIMITS
# =============================================================
MAX_EMAILS_PER_HOUR=10
MAX_PAYMENTS_PER_HOUR=3

# =============================================================
# WATCHER INTERVALS (seconds)
# =============================================================
GMAIL_CHECK_INTERVAL=120
WHATSAPP_CHECK_INTERVAL=30
FILESYSTEM_CHECK_INTERVAL=10
